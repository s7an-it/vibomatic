  "featureStates": [
    "DRAFT", "UX-REVIEWED", "DESIGNED", "BASELINED",
    "CHANGE-SET-APPROVED", "PROMOTED", "VERIFIED",
    "REJECTED", "PIVOTED"
  ],
  "reviewGates": {
    "G1": { "after": "write-spec", "transition": "DRAFT → UX-REVIEWED", "checks": "Stories testable? ACs specific? Layer 3 clean? Dependencies identified?" },
    "G2": { "after": "design-ux", "transition": "UX-REVIEWED → DESIGNED", "checks": "Flows cover all stories? States complete? Error handling? Accessibility?" },
    "G3": { "after": "design-ui", "transition": "DESIGNED → BASELINED", "checks": "Design system consistency? Responsive? Dark mode? Component reuse?" },
    "G4": { "after": "design-tech", "transition": "DESIGNED → BASELINED", "checks": "All ACs feasible? Architecture sound? Risks identified? Trade-offs explicit?" },
    "G5": { "after": "execute-changeset", "transition": "BASELINED → CHANGE-SET-APPROVED", "checks": "Executed branch diff matches design? Tasks cover ACs? Cross-file consistency? No placeholders? Task checkpoints clean?" },
    "G6": { "after": "land-changeset", "transition": "CHANGE-SET-APPROVED → PROMOTED", "checks": "Squash diff matches manifest file set? No unplanned changes? Validation clean?" },
    "G7": { "after": "verify-promotion", "transition": "final", "checks": "Tests pass? QA complete? E2E complete? Spec annotations updated?" }
  },
